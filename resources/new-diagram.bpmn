          <dc:Bounds x="188" y="235" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="432" y="192" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="440" y="235" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
