    <bpmn2:scriptTask id="_1385319E-20BB-42ED-B323-790B00E2FD55" name="Normalize Request" scriptFormat="java">
      <bpmn2:incoming>_9EFD4033-DF7A-4CF0-999E-24469D073F97</bpmn2:incoming>
      <bpmn2:outgoing>_2787A13B-A24B-4B82-8E4C-0BFBA7AF7E57</bpmn2:outgoing>
      <bpmn2:script>
com.sponsoredservices.EvaluationRequest req = (com.sponsoredservices.EvaluationRequest) kcontext.getVariable("request");
com.sponsoredservices.NormalizedEvaluationRequest norm = com.sponsoredservices.EvaluationRequestNormalizer.normalize(req);
kcontext.setVariable("normalizedRequest", norm);
      </bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="_C497DA48-4857-4417-A73A-2E54D4FCD6C3" name="Build Sponsorship Result" scriptFormat="java">
      <bpmn2:incoming>_E536D328-906A-4436-9FDB-7613077A5BC8</bpmn2:incoming>
      <bpmn2:outgoing>_656374EF-A393-4127-9587-06CEEDCC66A5</bpmn2:outgoing>
      <bpmn2:script>
com.sponsoredservices.NormalizedEvaluationRequest normalized = (com.sponsoredservices.NormalizedEvaluationRequest) kcontext.getVariable("normalizedRequest");
java.util.List contractsList = (java.util.List) kcontext.getVariable("contracts");
com.sponsoredservices.Contract matched = com.sponsoredservices.ContractMatcher.findFirstMatch(normalized, contractsList);
if (matched == null) {
  kcontext.setVariable("matchedContract", null);
  kcontext.setVariable("contractMatch", false);
  kcontext.setVariable("result", com.sponsoredservices.EvaluationResult.notSponsored("No contract matched"));
} else {
  kcontext.setVariable("matchedContract", matched);
  kcontext.setVariable("result", com.sponsoredservices.EvaluationResult.sponsored(
    matched.getContractId(),
    matched.getName(),
    java.util.List.of("Matched contract")
  ));
}
      </bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="_5E58092A-2AC8-441C-8A12-A55FB5C071FB" name="Build Non Sponsored Result" scriptFormat="java">
      <bpmn2:incoming>_42386C68-B94F-4019-AD88-C09328415F8C</bpmn2:incoming>
      <bpmn2:outgoing>_05E9CA57-A4EB-4434-9C77-1B962CA063E1</bpmn2:outgoing>
      <bpmn2:script>
kcontext.setVariable("matchedContract", null);
kcontext.setVariable("result", com.sponsoredservices.EvaluationResult.notSponsored("No contract matched"));
      </bpmn2:script>
    </bpmn2:scriptTask>
