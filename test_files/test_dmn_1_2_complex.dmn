<?xml version="1.0" encoding="UTF-8"?>
<dmn:definitions xmlns:dmn="http://www.omg.org/spec/DMN/20180521/MODEL/" xmlns="https://kiegroup.org/dmn/_52CEE37D-9CD0-4D1C-9D26-7ABCE6A1234B" xmlns:feel="http://www.omg.org/spec/DMN/20180521/FEEL/" xmlns:kie="http://www.drools.org/kie/dmn/1.2" xmlns:dmndi="http://www.omg.org/spec/DMN/20180521/DMNDI/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="_52CEE37D-9CD0-4D1C-9D26-7ABCE6A1234B" name="CheckDosageForm" typeLanguage="http://www.omg.org/spec/DMN/20180521/FEEL/" namespace="https://kiegroup.org/dmn/_52CEE37D-9CD0-4D1C-9D26-7ABCE6A1234B">
  <dmn:extensionElements/>
  <dmn:itemDefinition id="_Drug" name="Drug" isCollection="false">
    <dmn:itemComponent id="_Drug_id" name="id" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_Drug_name" name="name" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_Drug_dosage_form" name="dosage_form" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
  </dmn:itemDefinition>
  <dmn:inputData id="_drug" name="drug">
    <dmn:extensionElements/>
    <dmn:variable id="_drug_variable" name="drug" typeRef="Drug"/>
  </dmn:inputData>
  <dmn:decision id="_isTablet" name="isTablet">
    <dmn:extensionElements/>
    <dmn:variable id="_isTablet_variable" name="isTablet" typeRef="boolean"/>
    <dmn:informationRequirement id="_info_req_drug">
      <dmn:requiredInput href="#_drug"/>
    </dmn:informationRequirement>
    <dmn:decisionTable id="_decision_table" hitPolicy="UNIQUE" preferredOrientation="Rule-as-Row">
      <dmn:input id="_input_dosage_form">
        <dmn:inputExpression id="_input_dosage_form_expr" typeRef="string">
          <dmn:text>drug.dosage_form</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="_output_isTablet"/>
      <dmn:annotation name="annotation-1"/>
      <dmn:rule id="_rule_tabs">
        <dmn:inputEntry id="_rule_tabs_input">
          <dmn:text>"TABS"</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="_rule_tabs_output">
          <dmn:text>true</dmn:text>
        </dmn:outputEntry>
        <dmn:annotationEntry>
          <dmn:text>Is a tablet</dmn:text>
        </dmn:annotationEntry>
      </dmn:rule>
      <dmn:rule id="_rule_not_tabs">
        <dmn:inputEntry id="_rule_not_tabs_input">
          <dmn:text>not("TABS")</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="_rule_not_tabs_output">
          <dmn:text>false</dmn:text>
        </dmn:outputEntry>
        <dmn:annotationEntry>
          <dmn:text>Not a tablet</dmn:text>
        </dmn:annotationEntry>
      </dmn:rule>
    </dmn:decisionTable>
  </dmn:decision>
  <dmn:decisionService id="_checkDosageFormService" name="checkDosageForm">
    <dmn:variable id="_checkDosageFormService_variable" name="checkDosageForm" typeRef="boolean"/>
    <dmn:outputDecision href="#_isTablet"/>
    <dmn:inputData href="#_drug"/>
  </dmn:decisionService>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram>
      <di:extension>
        <kie:ComponentsWidthsExtension>
          <kie:ComponentWidths dmnElementRef="_decision_table">
            <kie:width>50</kie:width>
            <kie:width>200</kie:width>
            <kie:width>200</kie:width>
            <kie:width>200</kie:width>
          </kie:ComponentWidths>
        </kie:ComponentsWidthsExtension>
      </di:extension>
      <dmndi:DMNShape id="dmnshape-_drug" dmnElementRef="_drug" isCollapsed="false">
        <dc:Bounds x="150" y="200" width="100" height="50"/>
        <dmndi:DMNLabel/>
      </dmndi:DMNShape>
      <dmndi:DMNShape id="dmnshape-_isTablet" dmnElementRef="_isTablet" isCollapsed="false">
        <dc:Bounds x="150" y="80" width="100" height="50"/>
        <dmndi:DMNLabel/>
      </dmndi:DMNShape>
      <dmndi:DMNEdge id="dmnedge-_info_req_drug" dmnElementRef="_info_req_drug">
        <di:waypoint x="200" y="225"/>
        <di:waypoint x="200" y="105"/>
      </dmndi:DMNEdge>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</dmn:definitions>